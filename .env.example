NODE_ENV=production
PORT=3000

DB_HOST=your-mysql-host
DB_PORT=3306
DB_NAME=db_data_exchange_tools
DB_USER=dex_api
DB_PASSWORD=change-this-database-password

AUTH_SECRET=change-this-to-a-random-secret-at-least-32-characters
AGENT_ENROLLMENT_TOKEN=change-this-to-a-random-enrollment-token
# Optional: comma-separated legacy tokens for already-installed agents during migration.
# Remove after every agent has received a new per-machine Agent API key.
AGENT_LEGACY_ENROLLMENT_TOKENS=data-exchange-agent-enroll-dev-token
AGENT_ONLINE_TIMEOUT_SECONDS=60

CORS_ORIGIN=https://control.example.go.th
